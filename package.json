{
  "name": "subroutine-web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "supabase:login": "bunx supabase login",
    "supabase:gen_types": "bunx supabase gen types typescript --project-id 'skociusktxocudgkkoxe' --schema public > ./src/lib/types/database.types.ts && sed -i '' 's/data: Json | null/data: any/g' ./src/lib/types/database.types.ts && prettier --write ./src/lib/types/database.types.ts"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^9.39.4",
    "@number-flow/svelte": "^0.4.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.106.2",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.61.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.3.0",
    "@types/d3": "^7.4.3",
    "@types/node": "^20.19.41",
    "d3": "^7.9.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.18.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.2",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0",
    "valibot": "^1.4.1",
    "vite": "^7.3.3"
  }
}
